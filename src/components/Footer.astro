---
import { Image } from "@astrojs/image/components";
import AstroLogo from "../images/logomark-dark.png";
import GitHubLogo from "../images/GitHub-Mark-Light-32px.png";
---

<footer class="footer items-center p-4">
  <h5 class="items-center grid-flow-col">Built with Astro</h5>
  <div class="grid-flow-col gap-4 md:place-self-center md:justify-self-end">
    <a href="https://astro.build/" target="_blank" rel="noopener"
      ><Image
        src={AstroLogo}
        width={20}
        aspectRatio={1 / 1}
        quality={100}
        alt="Astro Logo"
      />
    </a>
    <a href="https://github.com/davidvekony/social-links-page" target="_blank"
      ><Image
        src={GitHubLogo}
        width={20}
        aspectRatio={1 / 1}
        quality={100}
        alt="GitHub Logo"
      />
    </a>
  </div>
</footer>
